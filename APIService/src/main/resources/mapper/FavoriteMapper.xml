<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.FavoriteMapper">
<!--    //收藏-->
    <insert id="insert">
        INSERT INTO favorite (user_id, post_id)
        VALUES (#{userId}, #{postId})
    </insert>

<!--    //取消收藏-->
    <delete id="deleteById">
        DELETE FROM favorite
        WHERE id = #{id}
    </delete>

<!--    //查询收藏-->
    <select id="selectByUserIdAndPostId" resultType="favorite">
        SELECT *
        FROM favorite
        WHERE user_id = #{userId}
          AND post_id = #{postId}
    </select>

    <!-- 批量查询当前用户收藏过的帖子ID -->
    <select id="selectCollectedPostIdsByUser" resultType="java.lang.Long">
        SELECT post_id
        FROM favorite
        WHERE user_id = #{userId}
        AND post_id IN
        <foreach collection="postIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 获取用户收藏的帖子ID列表（游标分页） -->
    <select id="selectCollectedPostIdsByUserId" resultType="java.lang.Long">
        SELECT post_id
        FROM favorite
        WHERE user_id = #{userId}
        <if test="lastId != null">
            AND post_id &lt; #{lastId}
        </if>
        ORDER BY post_id DESC
        LIMIT #{pageSize}
    </select>
</mapper>
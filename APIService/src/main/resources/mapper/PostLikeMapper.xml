<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.PostLikeMapper">
    <select id="selectByUserIdAndPostId">
        SELECT *
        FROM post_like
        WHERE user_id = #{userId}
          AND post_id = #{postId}
    </select>

    <!-- 批量查询当前用户点赞过的帖子ID -->
    <select id="selectLikedPostIdsByUser" resultType="java.lang.Long">
        SELECT post_id
        FROM post_like
        WHERE user_id = #{userId}
        AND post_id IN
        <foreach collection="postIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

<!--    //增加点赞-->
    <insert id="insert">
        INSERT INTO post_like (user_id, post_id)
        VALUES (#{userId}, #{postId})
    </insert>

<!--    //取消点赞-->
    <delete id="deleteById">
        DELETE FROM post_like
        WHERE id = #{id}
    </delete>

    <!-- 获取用户点赞的帖子ID列表（游标分页） -->
    <select id="selectLikedPostIdsByUserId" resultType="java.lang.Long">
        SELECT post_id
        FROM post_like
        WHERE user_id = #{userId}
        <if test="lastId != null">
            AND post_id &lt; #{lastId}
        </if>
        ORDER BY post_id DESC
        LIMIT #{pageSize}
    </select>
</mapper>
